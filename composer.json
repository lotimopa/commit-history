{
    "name": "lotimopa/commit-history",
    "description": "Fetch commit history from GitLab or GitHub repositories",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Spiriit",
            "email": "dev@spiriit.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.92",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Lotimopa\\CommitHistory\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lotimopa\\CommitHistory\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "cs-check": "vendor/bin/php-cs-fixer fix --verbose --diff --dry-run",
        "cs-fix": "vendor/bin/php-cs-fixer fix --verbose --diff",
        "test": "vendor/bin/phpunit"
    }
}
